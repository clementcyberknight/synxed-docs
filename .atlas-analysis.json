  "keyFeatures": [
    "Drop-in floating player UI with play/pause, skip, ads, artwork, and resume",
    "Low-level SynxedPlayer API for fully custom player UIs",
    "Songs, playlists, curated mixes, live radio, and scheduled stations",
    "Resumable playback with stable listener IDs",
    "Voice command support with hold-to-speak interaction",
    "Ad playback with skip countdowns and companion banners",
    "Discovery helpers for fetching stations, mixes, and schedules",
    "React, Next.js, Vue, and plain-HTML integrations",
    "Fully typed TypeScript API"
  ],
  "publicApiSurface": [
    "SynxedWebPlayer.mount(options)",
    "SynxedWebPlayer.destroy()",
    "new SynxedPlayer(config)",
    "player.playSong(options)",
    "player.playPlaylist(options)",
    "player.playMix(options)",
    "player.playRadio(options)",
    "player.playStation(options)",
    "player.pause() / player.resume() / player.stop()",
    "player.skip() / player.previous() / player.skipTo(index)",
    "player.seek(ms) / player.setVolume(volume)",
    "player.on(event, handler)",
    "player.beginVoiceHold(options) / player.endVoiceHold() / player.cancelVoiceHold()",
    "player.canSkipAd() / player.skipAd() / player.clickAd()",
    "player.dismissVoiceAndResume()",
    "fetchMixes(serverUrl, options)",
    "fetchStations(serverUrl, options)",
    "fetchStationSchedule(serverUrl, stationId, options)",
    "fetchRadioNowPlaying(serverUrl)",
    "SynxedError / SynxedConfigurationError / SynxedConnectionError / SynxedPlaybackError / SynxedProtocolError"
  ]
